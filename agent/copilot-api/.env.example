# Copy to .env (which is gitignored) and fill in real values.
# DO NOT commit a populated .env. The repo root .gitignore covers this file.

# Required: Anthropic API key. Used by app/llm.py.
ANTHROPIC_API_KEY=

# Default model. Haiku 4.5 is the cheapest model currently available
# under the API contract used by this project. Override per-environment.
COPILOT_MODEL=claude-haiku-4-5-20251001

# Shared secret for the OpenEMR PHP gateway -> sidecar hop. Must match the
# value set on the OpenEMR service environment.
COPILOT_OPENEMR_GATEWAY_SHARED_SECRET=

# dev | production. Controls verbosity of stored model output in traces.
COPILOT_ENV=dev

# Optional: Langfuse trace sink.
# NOTE: Use LANGFUSE_HOST (not LANGFUSE_BASE_URL — that is what the Cloud UI shows but the Python SDK reads HOST).
# EU Cloud (default):  https://cloud.langfuse.com
# US Cloud:            https://us.cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://us.cloud.langfuse.com

# Optional: trace cost estimates, USD per 1M tokens. Defaults match the
# planning/cost_analysis.md assumptions for Haiku 4.5 as of 2026-05.
# COPILOT_COST_INPUT_PER_1M=1.00
# COPILOT_COST_OUTPUT_PER_1M=5.00
# COPILOT_COST_CACHE_READ_PER_1M=0.10
# COPILOT_COST_CACHE_WRITE_PER_1M=1.25
