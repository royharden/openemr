# OpenEMR Modern Patient Dashboard — environment template
#
# Copy to .env.local and fill in the values for your local OpenEMR.
# .env.local is gitignored. Do NOT commit it.

# Root URL of the OpenEMR install. Used for OIDC discovery.
VITE_OPENEMR_BASE_URL=https://localhost:9300

# FHIR base URL — what fhirclient uses as `iss` and what it appends
# /.well-known/smart-configuration to during SMART discovery.
VITE_OPENEMR_FHIR_BASE_URL=https://localhost:9300/apis/default/fhir

# OpenEMR SMART client_id (public client). Obtain by registering the
# dashboard in OpenEMR's SMART app admin (see README.md "Register the
# SMART app"). Public client — no client_secret is used.
VITE_SMART_CLIENT_ID=

# Default SMART scopes requested at authorize time. NOTE: `Patient.rs`
# (read+search), NOT `Patient.r` (read-only-by-id).
VITE_DEFAULT_SCOPES=launch launch/patient openid fhirUser patient/Patient.rs patient/AllergyIntolerance.rs patient/Condition.rs patient/MedicationRequest.rs patient/CareTeam.rs patient/Observation.rs patient/Practitioner.rs

# 1 = boot MSW, route every fetch through fixtures (offline development).
# 0 = hit the real OpenEMR FHIR API.
VITE_USE_MSW=1
